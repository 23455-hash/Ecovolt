<Window x:Class="EcoVolt.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EcoVolt — Registro"
        Height="700" Width="1000"
        MinHeight="700" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#0D1117"
            CornerRadius="18"
            BorderBrush="#30363D"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="60" Opacity="0.8" ShadowDepth="0" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="18,0,0,18" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D1117" Offset="0"/>
                        <GradientStop Color="#080B0F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Ellipse Width="300" Height="300"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Opacity="0.05">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#32A76B" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="36,0">
                        <Image Source="/EcoVolt;component/Assets/logo.png"
                               Width="300" Height="300"
                               HorizontalAlignment="Center" Margin="0,0,0,16"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Effect>
                                <DropShadowEffect Color="#32A76B" BlurRadius="20" Opacity="0.3" ShadowDepth="0"/>
                            </Image.Effect>
                        </Image>

                        <Rectangle Height="1" Width="160" Margin="0,0,0,26">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#308BB1" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <TextBlock Text="Crea tu cuenta y empieza a controlar tu consumo eléctrico hoy mismo."
                                   FontSize="13" Foreground="#7D8590" FontFamily="Segoe UI"
                                   TextAlignment="Center" TextWrapping="Wrap" LineHeight="22"/>

                        <Border Background="#161B22" BorderBrush="#30363D"
                                BorderThickness="1" CornerRadius="10"
                                Padding="18,14" Margin="0,26,0,0">
                            <StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="24" Height="24" CornerRadius="6"
                                            Background="#0D2A1A" Margin="0,0,12,0">
                                        <TextBlock Text="📊" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Monitoreo en tiempo real"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#D7DAD8" FontFamily="Segoe UI"/>
                                        <TextBlock Text="Visualiza tu consumo al instante"
                                                   FontSize="10" Foreground="#7D8590" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="24" Height="24" CornerRadius="6"
                                            Background="#1A1A0A" Margin="0,0,12,0">
                                        <TextBlock Text="💡" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Historial de consumo"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#D7DAD8" FontFamily="Segoe UI"/>
                                        <TextBlock Text="Revisa tus registros pasados"
                                                   FontSize="10" Foreground="#7D8590" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Border Width="24" Height="24" CornerRadius="6"
                                            Background="#0D1A2A" Margin="0,0,12,0">
                                        <TextBlock Text="🔔" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Alertas de picos"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#D7DAD8" FontFamily="Segoe UI"/>
                                        <TextBlock Text="Detecta anomalías al instante"
                                                   FontSize="10" Foreground="#7D8590" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#0D1117">
                <Grid>
                    <Button Width="34" Height="34"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,12,12,0" Click="BtnClose_Click"
                            Cursor="Hand" Panel.ZIndex="10">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="8">
                                    <TextBlock Text="✕" FontSize="14" Foreground="#7D8590"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#3A1010"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <StackPanel VerticalAlignment="Center" Margin="50,0,50,0">
                        <TextBlock Text="Crear cuenta nueva"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="#D7DAD8" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                        <TextBlock Text="Completa el formulario para registrarte"
                                   FontSize="13" Foreground="#7D8590"
                                   FontFamily="Segoe UI" Margin="0,0,0,30"/>

                        <TextBlock Text="NOMBRE COMPLETO" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="#32A76B" FontFamily="Segoe UI" Margin="2,0,0,7"/>
                        <TextBox x:Name="txtName" Style="{StaticResource TxtModern}"/>

                        <TextBlock Text="CORREO ELECTRÓNICO" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="#32A76B" FontFamily="Segoe UI" Margin="2,16,0,7"/>
                        <TextBox x:Name="txtEmail" Style="{StaticResource TxtModern}"/>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CONTRASEÑA" FontSize="10.5" FontWeight="SemiBold"
                                           Foreground="#32A76B" FontFamily="Segoe UI" Margin="2,0,0,7"/>
                                <PasswordBox x:Name="txtPwd" Style="{StaticResource PwdModern}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="CONFIRMAR CONTRASEÑA" FontSize="10.5" FontWeight="SemiBold"
                                           Foreground="#32A76B" FontFamily="Segoe UI" Margin="2,0,0,7"/>
                                <PasswordBox x:Name="txtPwd2" Style="{StaticResource PwdModern}"/>
                            </StackPanel>
                        </Grid>

                        <Border x:Name="msgBox" Visibility="Collapsed"
                                CornerRadius="8" Padding="12,8" Margin="0,14,0,0">
                            <TextBlock x:Name="lblMsg" FontSize="12"
                                       FontFamily="Segoe UI" TextWrapping="Wrap"/>
                        </Border>

                        <Button Content="CREAR CUENTA"
                                Style="{StaticResource BtnPrimary}"
                                Margin="0,22,0,0"
                                Click="BtnRegister_Click"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,20,0,0">
                            <TextBlock Text="¿Ya tienes cuenta?  "
                                       Foreground="#7D8590" FontSize="13" FontFamily="Segoe UI"/>
                            <TextBlock Text="Inicia sesión"
                                       Foreground="#32A76B" FontSize="13"
                                       FontWeight="SemiBold" Cursor="Hand"
                                       FontFamily="Segoe UI"
                                       MouseLeftButtonDown="LnkLogin_Click">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>