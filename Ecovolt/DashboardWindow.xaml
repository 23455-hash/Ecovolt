<Window x:Class="EcoVolt.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="EcoVolt — Dashboard"
        Height="860" Width="1440"
        MinHeight="720" MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- RECURSOS INTERNOS DE LA VENTANA -->
    <Window.Resources>

        <!-- ══════════════════════════════════════════
             ESTILOS LOCALES (sidebar / cards)
        ══════════════════════════════════════════ -->

        <!-- Botón navegación sidebar — inactivo -->
        <Style x:Key="BtnNav" TargetType="Button">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="Foreground"              Value="#7D8590"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="FontFamily"              Value="Segoe UI"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height"                  Value="42"/>
            <Setter Property="Margin"                  Value="8,2,8,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="14,0,14,0">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#1A2535"/>
                                <Setter Property="Foreground" Value="#C8CCCA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón navegación sidebar — activo -->
        <Style x:Key="BtnNavActive" TargetType="Button" BasedOn="{StaticResource BtnNav}">
            <Setter Property="Background" Value="#1B3A2A"/>
            <Setter Property="Foreground" Value="#32A76B"/>
        </Style>

        <!-- Tarjeta general del dashboard -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="#161B22"/>
            <Setter Property="BorderBrush"      Value="#1C2128"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="12"/>
            <Setter Property="Padding"          Value="20"/>
            <Setter Property="Margin"           Value="0,0,0,0"/>
        </Style>

        <!-- ComboBox moderno -->
        <Style x:Key="CbModern" TargetType="ComboBox">
            <Setter Property="Background"       Value="#161B22"/>
            <Setter Property="Foreground"       Value="#7D8590"/>
            <Setter Property="BorderBrush"      Value="#30363D"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="Height"           Value="34"/>
            <Setter Property="Padding"          Value="10,0"/>
        </Style>

        <!-- TextBox moderno -->
        <Style x:Key="TxtModern" TargetType="TextBox">
            <Setter Property="Background"       Value="#161B22"/>
            <Setter Property="Foreground"       Value="#C8CCCA"/>
            <Setter Property="BorderBrush"      Value="#30363D"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="Padding"          Value="8,6"/>
        </Style>

    </Window.Resources>

    <Border Background="#0D1117" CornerRadius="14"
            BorderBrush="#1C2128" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="60" Opacity="0.85"
                              ShadowDepth="0" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════
                 SIDEBAR
            ══════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="#080B0F"
                    CornerRadius="14,0,0,14"
                    BorderBrush="#1C2128"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- LOGO -->
                    <StackPanel Grid.Row="0" Margin="0,22,0,16"
                                HorizontalAlignment="Center">
                        <Image Source="/EcoVolt;component/Assets/logo.png"
                               Width="190" Height="90"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="ECOVOLT"
                                   FontSize="13" FontWeight="Black"
                                   FontFamily="Segoe UI Black"
                                   Foreground="#32A76B"
                                   HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#32A76B" BlurRadius="12"
                                                  Opacity="0.45" ShadowDepth="0"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Smart IoT Energy Solutions"
                                   FontSize="8.5" Foreground="#2A3A2F"
                                   FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Rectangle Grid.Row="0" Height="1"
                               VerticalAlignment="Bottom"
                               Margin="18,0,18,0" Fill="#161B22"/>

                    <!-- MENÚ -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Hidden">
                        <StackPanel Margin="0,12,0,10">

                            <TextBlock Text="PRINCIPAL"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="#2A3A35"
                                       FontFamily="Segoe UI"
                                       Margin="22,6,0,8"/>

                            <Button x:Name="btnNavDashboard"
                                    Style="{StaticResource BtnNavActive}"
                                    Click="NavDashboard_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏠" FontSize="13" Margin="0,0,10,0"/>
                                    <TextBlock Text="Inicio" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btnNavConsumo"
                                    Style="{StaticResource BtnNav}"
                                    Click="NavConsumo_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="13" Margin="0,0,10,0"/>
                                    <TextBlock Text="Consumo" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btnNavHistorial"
                                    Style="{StaticResource BtnNav}"
                                    Click="NavHistorial_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="13" Margin="0,0,10,0"/>
                                    <TextBlock Text="Historial" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btnNavAlertas"
                                    Style="{StaticResource BtnNav}"
                                    Click="NavAlertas_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔔" FontSize="13" Margin="0,0,10,0"/>
                                    <TextBlock Text="Alertas" VerticalAlignment="Center"/>
                                    <Border x:Name="badgeAlertas"
                                            Background="#EF4444"
                                            CornerRadius="10"
                                            Padding="6,1,6,1"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                        <TextBlock x:Name="lblBadgeCount"
                                                   Text="0"
                                                   FontSize="10"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontFamily="Segoe UI"/>
                                    </Border>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btnNavPredicciones"
                                    Style="{StaticResource BtnNav}"
                                    Click="NavPredicciones_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔮" FontSize="13" Margin="0,0,10,0"/>
                                    <TextBlock Text="Predicciones" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btnNavMultimetro"
                                    Style="{StaticResource BtnNav}"
                                    Click="NavMultimetro_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏱" FontSize="13" Margin="0,0,10,0"/>
                                    <TextBlock Text="Multímetro" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btnNavReportes"
                                    Style="{StaticResource BtnNav}"
                                    Click="NavReportes_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📈" FontSize="13" Margin="0,0,10,0"/>
                                    <TextBlock Text="Reportes / Power BI"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Rectangle Height="1" Margin="18,14,18,14"
                                       Fill="#161B22"/>

                            <TextBlock Text="SISTEMA"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="#2A3A35"
                                       FontFamily="Segoe UI"
                                       Margin="22,0,0,8"/>

                            <Button x:Name="btnNavDispositivos"
                                    Style="{StaticResource BtnNav}"
                                    Click="NavDispositivos_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔌" FontSize="13" Margin="0,0,10,0"/>
                                    <TextBlock Text="Dispositivos"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btnNavConfig"
                                    Style="{StaticResource BtnNav}"
                                    Click="NavConfig_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" FontSize="13" Margin="0,0,10,0"/>
                                    <TextBlock Text="Configuración"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- FOOTER SIDEBAR -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,16">
                        <Rectangle Height="1" Margin="18,0,18,12" Fill="#161B22"/>
                        <StackPanel Orientation="Horizontal" Margin="22,0,0,10">
                            <Ellipse x:Name="elDB" Width="7" Height="7"
                                     Fill="#32A76B" Margin="0,0,8,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#32A76B" BlurRadius="6"
                                                      Opacity="0.7" ShadowDepth="0"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock x:Name="lblDBStatus"
                                       Text="SQL Conectado"
                                       FontSize="10" Foreground="#4A6055"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                        <Button Style="{StaticResource BtnNav}"
                                Click="BtnLogout_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚪" FontSize="13" Margin="0,0,10,0"/>
                                <TextBlock Text="Cerrar sesión"
                                           Foreground="#EF4444"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════
                 ÁREA PRINCIPAL
            ══════════════════════════════════════ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TOPBAR -->
                <Border Grid.Row="0" Background="#0A0D12"
                        BorderBrush="#161B22" BorderThickness="0,0,0,1">
                    <Grid Margin="24,0,16,0">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="lblPageTitle"
                                       Text="Panel de análisis"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="#C8CCCA"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       Margin="0,0,18,0"/>
                            <ComboBox x:Name="cbPeriodo"
                                      Style="{StaticResource CbModern}"
                                      Width="130"
                                      SelectionChanged="CbPeriodo_Changed">
                                <ComboBoxItem Content="Hoy" IsSelected="True"/>
                                <ComboBoxItem Content="Esta semana"/>
                                <ComboBoxItem Content="Este mes"/>
                                <ComboBoxItem Content="Este año"/>
                            </ComboBox>
                            <Button Height="34" Width="118"
                                    Margin="10,0,0,0"
                                    Cursor="Hand"
                                    Click="BtnRefresh_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd"
                                                Background="#161B22"
                                                BorderBrush="#30363D"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <ContentPresenter
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background"
                                                        Value="#1C2128"/>
                                                <Setter TargetName="bd" Property="BorderBrush"
                                                        Value="#32A76B"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↻" FontSize="14"
                                               Foreground="#32A76B"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Actualizar"
                                               FontSize="12"
                                               Foreground="#7D8590"
                                               FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="lblDateTime"
                                       FontSize="11"
                                       Foreground="#2A3A35"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       Margin="0,0,18,0"/>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,18,0">
                                <Ellipse Width="7" Height="7"
                                         Fill="#32A76B" Margin="0,0,6,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#32A76B"
                                                          BlurRadius="6"
                                                          Opacity="0.9"
                                                          ShadowDepth="0"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="EN VIVO"
                                           FontSize="9.5"
                                           Foreground="#32A76B"
                                           FontWeight="SemiBold"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                            <TextBlock x:Name="lblGreeting"
                                       FontSize="12"
                                       Foreground="#4A5A55"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       Margin="0,0,18,0"/>
                            <Button Width="34" Height="34"
                                    Click="BtnClose_Click" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd"
                                                Background="Transparent"
                                                CornerRadius="8">
                                            <TextBlock Text="✕"
                                                       FontSize="14"
                                                       Foreground="#4A5A55"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd"
                                                        Property="Background"
                                                        Value="#3A1010"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════
                     PAGE 1: INICIO / DASHBOARD
                ══════════════════════════════════ -->
                <ScrollViewer x:Name="pageDashboard"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="#0D1117">
                    <StackPanel Margin="20,18,20,24">

                        <!-- KPIs: 6 tarjetas -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!-- KPI 1: Potencia -->
                            <Border Grid.Column="0" Style="{StaticResource Card}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,8">
                                        <TextBlock Text="⚡" FontSize="18"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="POTENCIA ACTUAL"
                                                   FontSize="9.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="#4A6055"
                                                   FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="lblPotencia"
                                               Text="— kW"
                                               FontSize="26" FontWeight="Black"
                                               Foreground="#D7DAD8"
                                               FontFamily="Segoe UI Black"/>
                                    <TextBlock Text="Pico en período seleccionado"
                                               FontSize="10"
                                               Foreground="#2A3A35"
                                               FontFamily="Segoe UI"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- KPI 2: Consumo -->
                            <Border Grid.Column="2" Style="{StaticResource Card}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,8">
                                        <TextBlock Text="📊" FontSize="18"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="CONSUMO PERÍODO"
                                                   FontSize="9.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="#4A6055"
                                                   FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="lblConsumo"
                                               Text="— kWh"
                                               FontSize="26" FontWeight="Black"
                                               Foreground="#D7DAD8"
                                               FontFamily="Segoe UI Black"/>
                                    <TextBlock Text="Energía acumulada total"
                                               FontSize="10"
                                               Foreground="#2A3A35"
                                               FontFamily="Segoe UI"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- KPI 3: Costo -->
                            <Border Grid.Column="4" Style="{StaticResource Card}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,8">
                                        <TextBlock Text="💰" FontSize="18"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="COSTO ESTIMADO"
                                                   FontSize="9.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="#4A6055"
                                                   FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="lblCosto"
                                               Text="$ —"
                                               FontSize="26" FontWeight="Black"
                                               Foreground="#D7DAD8"
                                               FontFamily="Segoe UI Black"/>
                                    <TextBlock Text="COP · Tarifa 800/kWh"
                                               FontSize="10"
                                               Foreground="#2A3A35"
                                               FontFamily="Segoe UI"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- KPI 4: Promedio -->
                            <Border Grid.Column="6" Style="{StaticResource Card}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,8">
                                        <TextBlock Text="📉" FontSize="18"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="CONSUMO PROMEDIO"
                                                   FontSize="9.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="#4A6055"
                                                   FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="lblPromedio"
                                               Text="— W"
                                               FontSize="26" FontWeight="Black"
                                               Foreground="#D7DAD8"
                                               FontFamily="Segoe UI Black"/>
                                    <TextBlock Text="Promedio por registro"
                                               FontSize="10"
                                               Foreground="#2A3A35"
                                               FontFamily="Segoe UI"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- KPI 5: Dispositivos -->
                            <Border Grid.Column="8" Style="{StaticResource Card}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,8">
                                        <TextBlock Text="🔌" FontSize="18"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="DISPOSITIVOS"
                                                   FontSize="9.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="#4A6055"
                                                   FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="lblDispositivos"
                                               Text="—"
                                               FontSize="26" FontWeight="Black"
                                               Foreground="#D7DAD8"
                                               FontFamily="Segoe UI Black"/>
                                    <TextBlock Text="Equipos activos"
                                               FontSize="10"
                                               Foreground="#2A3A35"
                                               FontFamily="Segoe UI"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- KPI 6: Estado -->
                            <Border Grid.Column="10" Style="{StaticResource Card}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,8">
                                        <TextBlock Text="🛡️" FontSize="18"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="ESTADO GENERAL"
                                                   FontSize="9.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="#4A6055"
                                                   FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="lblEstadoGeneral"
                                               Text="Normal"
                                               FontSize="22" FontWeight="Black"
                                               Foreground="#32A76B"
                                               FontFamily="Segoe UI Black"/>
                                    <TextBlock x:Name="lblAlertasActivas"
                                               Text="0 alertas activas"
                                               FontSize="10"
                                               Foreground="#2A3A35"
                                               FontFamily="Segoe UI"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- FILA 2: Top dispositivos + Resumen alertas -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="320"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="🏆 Top Dispositivos por Consumo"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#C8CCCA"
                                               FontFamily="Segoe UI"
                                               Margin="0,0,0,16"/>
                                    <StackPanel x:Name="topDispositivosPanel"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="🔔 Alertas Recientes"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#C8CCCA"
                                               FontFamily="Segoe UI"
                                               Margin="0,0,0,14"/>
                                    <StackPanel x:Name="alertasResumenPanel"/>
                                    <Button Content="Ver todas las alertas →"
                                            Margin="0,12,0,0" Height="32"
                                            Cursor="Hand"
                                            Click="NavAlertas_Click"
                                            Foreground="#32A76B"
                                            FontSize="11"
                                            FontFamily="Segoe UI">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd"
                                                        Background="Transparent"
                                                        BorderBrush="#1C2128"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <ContentPresenter
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter TargetName="bd"
                                                                Property="BorderBrush"
                                                                Value="#32A76B"/>
                                                        <Setter TargetName="bd"
                                                                Property="Background"
                                                                Value="#0D1E14"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- FILA 3: Predicción rápida -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,14">
