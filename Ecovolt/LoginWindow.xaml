<Window x:Class="EcoVolt.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EcoVolt — Login"
        Height="640" Width="1000"
        MinHeight="640" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#0D1117"
            CornerRadius="18"
            BorderBrush="#30363D"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="60" Opacity="0.8" ShadowDepth="0" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ LEFT: BRANDING ══ -->
            <Border Grid.Column="0" CornerRadius="18,0,0,18" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D1117" Offset="0"/>
                        <GradientStop Color="#080B0F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Círculo decorativo verde -->
                    <Ellipse Width="340" Height="340"
                             HorizontalAlignment="Center" VerticalAlignment="Top"
                             Margin="0,-130,0,0" Opacity="0.06">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#32A76B" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- Círculo decorativo azul -->
                    <Ellipse Width="200" Height="200"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-60,0,0,60" Opacity="0.07">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#308BB1" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40,0">

                        <!-- ★ LOGO IMAGE (PNG real del proyecto) -->
                        <!-- Asegúrate de haber agregado logo.png en la carpeta Assets con Build Action = Resource -->
                        <Image Source="/EcoVolt;component/Assets/logo.png"
                               Width="300" Height="300"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Effect>
                                <DropShadowEffect Color="#32A76B" BlurRadius="20" Opacity="0.3" ShadowDepth="0"/>
                            </Image.Effect>
                        </Image>

                        <!-- Separador -->
                        <Rectangle Height="1" Width="180" Margin="0,0,0,28">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#32A76B" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Descripción -->
                        <TextBlock Text="Monitorea y optimiza tu consumo eléctrico en tiempo real."
                                   FontSize="13" Foreground="#7D8590" FontFamily="Segoe UI"
                                   TextAlignment="Center" TextWrapping="Wrap" LineHeight="22"/>

                        <!-- Feature list -->
                        <Border Background="#161B22" BorderBrush="#30363D"
                                BorderThickness="1" CornerRadius="10"
                                Padding="18,14" Margin="0,28,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="24" Height="24" CornerRadius="6"
                                            Background="#0D2A1A" Margin="0,0,12,0">
                                        <TextBlock Text="📊" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Monitoreo en Tiempo Real"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#D7DAD8" FontFamily="Segoe UI"/>
                                        <TextBlock Text="Visualiza tu consumo al instante"
                                                   FontSize="10" Foreground="#7D8590" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="24" Height="24" CornerRadius="6"
                                            Background="#0D1A2A" Margin="0,0,12,0">
                                        <TextBlock Text="🔔" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Alertas Inteligentes"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#D7DAD8" FontFamily="Segoe UI"/>
                                        <TextBlock Text="Detecta picos de consumo"
                                                   FontSize="10" Foreground="#7D8590" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="24" Height="24" CornerRadius="6"
                                            Background="#1A1A0A" Margin="0,0,12,0">
                                        <TextBlock Text="💡" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Ahorro Energético"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#D7DAD8" FontFamily="Segoe UI"/>
                                        <TextBlock Text="Reduce tu factura mensual"
                                                   FontSize="10" Foreground="#7D8590" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ RIGHT: LOGIN FORM ══ -->
            <Border Grid.Column="1" Background="#0D1117">
                <!-- Close button -->
                <Grid>
                    <Button Width="34" Height="34"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,12,12,0" Click="BtnClose_Click"
                            Cursor="Hand" Panel.ZIndex="10">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="8">
                                    <TextBlock Text="✕" FontSize="14" Foreground="#7D8590"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#3A1010"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <StackPanel VerticalAlignment="Center" Margin="52,0,52,0">
                        <TextBlock Text="Bienvenido de vuelta"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="#D7DAD8" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                        <TextBlock Text="Ingresa tus credenciales para acceder a tu panel"
                                   FontSize="13" Foreground="#7D8590"
                                   FontFamily="Segoe UI" Margin="0,0,0,36"/>

                        <!-- Email -->
                        <TextBlock Text="CORREO ELECTRÓNICO" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="#32A76B" FontFamily="Segoe UI" Margin="2,0,0,7"/>
                        <TextBox x:Name="txtEmail" Style="{StaticResource TxtModern}"/>

                        <!-- Password -->
                        <TextBlock Text="CONTRASEÑA" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="#32A76B" FontFamily="Segoe UI"
                                   Margin="2,18,0,7"/>
                        <PasswordBox x:Name="txtPwd" Style="{StaticResource PwdModern}"/>

                        <!-- Error box -->
                        <Border x:Name="msgBox" Visibility="Collapsed"
                                CornerRadius="8" Padding="12,8" Margin="0,14,0,0">
                            <TextBlock x:Name="lblMsg" FontSize="12"
                                       FontFamily="Segoe UI" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Login button -->
                        <Button Content="INICIAR SESIÓN"
                                Style="{StaticResource BtnPrimary}"
                                Margin="0,24,0,0"
                                Click="BtnLogin_Click"/>

                        <!-- Register link -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,22,0,0">
                            <TextBlock Text="¿No tienes cuenta?  "
                                       Foreground="#7D8590" FontSize="13" FontFamily="Segoe UI"/>
                            <TextBlock Text="Regístrate aquí"
                                       Foreground="#32A76B" FontSize="13"
                                       FontWeight="SemiBold" Cursor="Hand"
                                       FontFamily="Segoe UI"
                                       MouseLeftButtonDown="LnkRegister_Click">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>