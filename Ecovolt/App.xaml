<Application x:Class="EcoVolt.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="LoginWindow.xaml">
    <Application.Resources>

        <!-- ════ BRUSHES — Paleta EcoVolt ════ -->
        <SolidColorBrush x:Key="BgDark"      Color="#0D1117"/>
        <SolidColorBrush x:Key="BgMid"       Color="#161B22"/>
        <SolidColorBrush x:Key="BgCard"      Color="#1C2128"/>
        <SolidColorBrush x:Key="BgInput"     Color="#21262D"/>
        <SolidColorBrush x:Key="Sidebar"     Color="#080B0F"/>
        <SolidColorBrush x:Key="Primary"     Color="#32A76B"/>
        <SolidColorBrush x:Key="PrimaryL"    Color="#63C768"/>
        <SolidColorBrush x:Key="Secondary"   Color="#308BB1"/>
        <SolidColorBrush x:Key="SecondaryL"  Color="#32A6C5"/>
        <SolidColorBrush x:Key="BorderCol"   Color="#30363D"/>
        <SolidColorBrush x:Key="TextPrim"    Color="#D7DAD8"/>
        <SolidColorBrush x:Key="TextSec"     Color="#7D8590"/>
        <SolidColorBrush x:Key="GreenAcc"    Color="#63C768"/>
        <SolidColorBrush x:Key="RedAcc"      Color="#EF4444"/>
        <SolidColorBrush x:Key="OrangeAcc"   Color="#F97316"/>

        <!-- ════ BUTTON: PRIMARY (verde) ════ -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#32A76B"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect Color="#32A76B" BlurRadius="14" Opacity="0.3" ShadowDepth="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#63C768"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E7A4A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#1A2A20"/>
                                <Setter Property="Foreground" Value="#444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ════ BUTTON: GHOST (contorno azul) ════ -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#32A6C5"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush"     Value="#308BB1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0D2030"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ════ BUTTON: SIDEBAR NAV ════ -->
        <Style x:Key="BtnNav" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#7D8590"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="8,1">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#161B22"/>
                                <Setter Property="Foreground" Value="#D7DAD8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ════ BUTTON: SIDEBAR NAV ACTIVO ════ -->
        <Style x:Key="BtnNavActive" TargetType="Button" BasedOn="{StaticResource BtnNav}">
            <Setter Property="Background" Value="#0D2A1A"/>
            <Setter Property="Foreground" Value="#32A76B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- ════ TEXTBOX ════ -->
        <Style x:Key="TxtModern" TargetType="TextBox">
            <Setter Property="Background"              Value="#21262D"/>
            <Setter Property="Foreground"              Value="#D7DAD8"/>
            <Setter Property="CaretBrush"              Value="#32A76B"/>
            <Setter Property="SelectionBrush"          Value="#32A76B"/>
            <Setter Property="BorderBrush"             Value="#30363D"/>
            <Setter Property="BorderThickness"         Value="1.5"/>
            <Setter Property="Height"                  Value="48"/>
            <Setter Property="FontSize"                Value="14"/>
            <Setter Property="FontFamily"              Value="Segoe UI"/>
            <Setter Property="Padding"                 Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#32A76B"/>
                                <Setter TargetName="bd" Property="Background" Value="#1A2D22"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#308BB1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ════ PASSWORDBOX ════ -->
        <Style x:Key="PwdModern" TargetType="PasswordBox">
            <Setter Property="Background"              Value="#21262D"/>
            <Setter Property="Foreground"              Value="#D7DAD8"/>
            <Setter Property="CaretBrush"              Value="#32A76B"/>
            <Setter Property="SelectionBrush"          Value="#32A76B"/>
            <Setter Property="BorderBrush"             Value="#30363D"/>
            <Setter Property="BorderThickness"         Value="1.5"/>
            <Setter Property="Height"                  Value="48"/>
            <Setter Property="FontSize"                Value="14"/>
            <Setter Property="FontFamily"              Value="Segoe UI"/>
            <Setter Property="Padding"                 Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#32A76B"/>
                                <Setter TargetName="bd" Property="Background" Value="#1A2D22"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#308BB1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ════ CARD BORDER ════ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="#1C2128"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="20"/>
        </Style>

        <!-- ════ COMBOBOX ════ -->
        <Style x:Key="CbModern" TargetType="ComboBox">
            <Setter Property="Background"      Value="#21262D"/>
            <Setter Property="Foreground"      Value="#D7DAD8"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Padding"         Value="10,0"/>
        </Style>

    </Application.Resources>
</Application>